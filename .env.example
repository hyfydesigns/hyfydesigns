# Printful — leave empty to use mock catalog and mocked orders
PRINTFUL_API_KEY=

# Second Printful store (Shopify-connected) — used only for one-off
# description sync into Sanity. Leave empty if not using.
PRINTFUL_SHOPIFY_API_KEY=

# Stripe — leave empty to use mocked checkout that skips payment
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Transactional email (Resend recommended)
RESEND_API_KEY=
CONTACT_EMAIL_TO=hello@hyfydesigns.com

# File uploads (Uploadthing or Cloudinary)
UPLOADTHING_SECRET=
UPLOADTHING_APP_ID=

# PostHog product analytics — leave empty to disable
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# Sanity CMS
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production
SANITY_API_READ_TOKEN=
