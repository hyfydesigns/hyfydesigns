# Printful — leave empty to use mock catalog and mocked orders
PRINTFUL_API_KEY=

# Shopify Admin API — optional, used only for one-off product description
# sync from a Shopify store into Sanity productContent docs.
SHOPIFY_STORE_DOMAIN=
SHOPIFY_ADMIN_ACCESS_TOKEN=

# Stripe — leave empty to use mocked checkout that skips payment
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Transactional email (Resend)
RESEND_API_KEY=
# Where inbound form messages are delivered. Defaults to
# hyfydesigns2020@gmail.com when unset.
CONTACT_EMAIL_TO=
# Verified Resend sender for outbound mail. Falls back to
# "HyFy Designs <onboarding@resend.dev>" (Resend's shared sender) when
# unset, which works immediately but is less trusted by inboxes.
CONTACT_EMAIL_FROM=
# Optional Resend audience ID used to add newsletter signups to a list.
# Without this, welcome emails still send but no contact record is
# created in Resend.
RESEND_AUDIENCE_ID=

# HMAC secret used to sign unsubscribe links. Any random string works.
# Falls back to a default when unset (fine for MVP, tighten later).
UNSUBSCRIBE_SECRET=

# File uploads (Uploadthing or Cloudinary)
UPLOADTHING_SECRET=
UPLOADTHING_APP_ID=

# PostHog product analytics — leave empty to disable
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# Sanity CMS
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production
SANITY_API_READ_TOKEN=
# Editor-permission Sanity token, used by the description sync endpoint.
SANITY_API_WRITE_TOKEN=

# Shared secret protecting /api/admin/* endpoints. Any random string.
ADMIN_SYNC_TOKEN=
